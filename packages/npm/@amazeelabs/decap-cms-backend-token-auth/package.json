{
  "name": "@amazeelabs/decap-cms-backend-token-auth",
  "version": "1.2.6",
  "description": "",
  "main": "index.js",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./proxy": {
      "import": "./build/proxy.js"
    },
    "./backend": {
      "import": "./build/backend.js"
    }
  },
  "typesVersions": {
    "*": {
      "proxy": [
        "build/proxy.d.ts"
      ],
      "backend": [
        "build/backend.d.ts"
      ]
    }
  },
  "scripts": {
    "test:static": "tsc --noEmit && eslint . --quiet",
    "test:unit": "vitest run --passWithNoTests",
    "prep": "rm -rf build && tsc -p tsconfig.build.json",
    "build": "pnpm prep",
    "watch": "tsc --watch -p tsconfig.build.json"
  },
  "dependencies": {
    "@amazeelabs/token-auth-middleware": "workspace:*",
    "@emotion/styled": "^11.14.0",
    "decap-cms-backend-github": "^3.2.2",
    "decap-cms-lib-util": "^3.1.0",
    "decap-cms-ui-default": "^3.1.4"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@octokit/types": "13.7.0",
    "@types/js-cookie": "3.0.6",
    "@types/node": "18.19.74",
    "@types/react": "18.3.18",
    "@types/semaphore": "1.1.4",
    "js-cookie": "3.0.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "keywords": [],
