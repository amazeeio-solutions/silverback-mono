{
  "name": "@amazeelabs/executors",
  "version": "3.1.14",
  "description": "",
  "types": "build/client.d.ts",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "prep": "tsup src/client.tsx src/server.tsx --dts --format esm --out-dir build",
    "watch": "pnpm prep --watch",
    "build": "pnpm prep",
    "test:unit": "vitest run",
    "test:static": "tsc --noEmit && eslint . --quiet",
    "test:integration": "playwright install chromium && playwright test",
    "test:cmd": "cd test && ../node_modules/waku/cli.js",
    "test:dev": "pnpm test:cmd dev",
    "test:start": "pnpm test:cmd build && pnpm test:cmd start",
    "test:all": "pnpm test:unit && pnpm test:static && pnpm test:integration"
  },
  "exports": {
    ".": {
      "react-server": "./build/server.js",
      "default": "./build/client.js"
    }
  },
  "keywords": [],
  "author": "Amazee Labs <development@amazeelabs.com>",
  "license": "ISC",
  "dependencies": {
    "@amazeelabs/codegen-operation-ids": "workspace:*",
    "lodash-es": "^4.17.21",
    "react-server-dom-webpack": "19.0.1",
    "server-only-context": "^0.1.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "devDependencies": {
    "@amazeelabs/prettier-config": "1.1.3",
    "@internal/eslint-config": "workspace:*",
    "@playwright/test": "1.50.0",
    "@testing-library/react": "16.2.0",
    "@types/lodash-es": "4.17.12",
    "@types/node": "20.17.16",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "jsdom": "25.0.1",
    "playwright": "1.50.0",
    "prettier": "3.4.2",
    "react": "19.0.0-rc.0",
    "react-dom": "19.0.0",
    "ts-expect": "1.3.0",
    "tsup": "8.3.6",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "waku": "0.21.17"
  }
}
