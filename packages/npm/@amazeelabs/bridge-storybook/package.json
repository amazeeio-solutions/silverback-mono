{
  "name": "@amazeelabs/bridge-storybook",
  "version": "1.2.25",
  "description": "Bridge implementation for storybook.",
  "type": "module",
  "main": "./build/src/index.js",
  "types": "./build/index.d.ts",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf build && swc ./src -d ./build && tsc --emitDeclarationOnly",
    "test:static": "tsc --noEmit && eslint . --quiet"
  },
  "peerDependencies": {
    "@storybook/addon-actions": ">=8.5.2",
    "react": ">=18.3.1"
  },
  "devDependencies": {
    "@amazeelabs/bridge": "workspace:*",
    "@internal/eslint-config": "workspace:*",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.11",
    "@types/react": "18.3.18",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "keywords": [],
  "author": "AmazeeLabs <development@amazeelabs.com>"
}
