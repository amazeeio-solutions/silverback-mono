{
  "name": "@amazeelabs/mzx",
  "version": "1.4.40",
  "description": "Executable markdown recipes.",
  "main": "dist/index.js",
  "bin": "./cli.js",
  "license": "MIT",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "fs-extra": "^11.3.0",
    "js-yaml": "^4.1.0",
    "prompts": "^2.4.2",
    "remark-parse": "^10.0.2",
    "unified": "^10.1.2",
    "zx": "^8.3.0"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@rollup/plugin-node-resolve": "16.0.0",
    "@rollup/plugin-typescript": "12.1.2",
    "@types/diff": "6.0.0",
    "@types/fs-extra": "11.0.4",
    "@types/js-yaml": "4.0.9",
    "@types/mdast": "3.0.11",
    "@types/prompts": "2.4.9",
    "rollup": "4.32.0",
    "rollup-plugin-auto-external": "2.0.0",
    "typescript": "5.7.3",
    "vite": "6.0.11",
    "vitest": "2.1.8"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "test:static": "tsc --noEmit && eslint . --quiet",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "PROJECT_NAME=test_project ./cli.js run test.md",
    "test:watch": "vitest"
  }
}
