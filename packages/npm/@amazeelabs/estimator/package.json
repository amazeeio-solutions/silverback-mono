{
  "name": "@amazeelabs/estimator",
  "version": "1.2.6",
  "description": "Estimate projects based on GraphQL definitions.",
  "main": "index.js",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "amazeelabs-estimator": "./cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@effect/platform": "^0.53.4",
    "@effect/platform-node": "^0.49.4",
    "@effect/schema": "0.67.18",
    "@graphql-tools/graphql-tag-pluck": "^8.3.12",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "effect": "^3.1.4",
    "glob": "11.0.1",
    "glob-watcher": "6.0.0",
    "graphql": "^16.10.0",
    "ink": "^5.1.0",
    "micromatch": "^4.0.8",
    "react": "^18.3.1",
    "simple-git": "^3.27.0",
    "ts-import": "^5.0.0-beta.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@amazeelabs/prettier-config": "^1.1.3",
    "@effect/vitest": "^0.4.3",
    "@internal/eslint-config": "workspace:*",
    "@types/glob": "^8.1.0",
    "@types/micromatch": "4.0.9",
    "@types/react": "18.3.18",
    "msw": "2.7.0",
    "prettier": "^3.4.2",
    "tsup": "^8.0.2",
    "typescript": "^5.7.3",
    "vitest": "2.1.8"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm && tsup src/index.ts --dts --format esm",
    "watch": "tsup src/cli.ts --format esm --watch",
    "test:static": "tsc --noEmit && eslint . --quiet",
    "test:unit": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "estimator": "cd test/full && node ../../cli.js"
  }
}
