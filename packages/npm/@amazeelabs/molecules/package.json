{
  "name": "@amazeelabs/molecules",
  "version": "0.5.53",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "private": false,
  "sideEffects": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test:static": "tsc --noEmit && eslint . --quiet",
    "test:unit": "vitest run --passWithNoTests && pnpm build-storybook",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "storybook": "storybook dev -p 6007 --ci",
    "build-storybook": "storybook build",
    "deploy": "pnpm build-storybook && pnpm run --filter=@amazeelabs/molecules netlify deploy -a $NETLIFY_AUTH_TOKEN -d packages/npm/@amazeelabs/molecules/storybook-static -p -s amazeelabs-molecules"
  },
  "peerDependencies": {
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "7.26.7",
    "@internal/eslint-config": "workspace:*",
    "@mdx-js/react": "3.1.0",
    "@storybook/addon-actions": "8.5.2",
    "@storybook/addon-backgrounds": "8.5.2",
    "@storybook/addon-docs": "8.5.2",
    "@storybook/addon-essentials": "8.5.2",
    "@storybook/addon-interactions": "8.5.2",
    "@storybook/addon-links": "8.5.2",
    "@storybook/addon-mdx-gfm": "8.5.2",
    "@storybook/addon-measure": "8.5.2",
    "@storybook/addon-outline": "8.5.2",
    "@storybook/addons": "7.6.17",
    "@storybook/channel-postmessage": "7.6.17",
    "@storybook/channel-websocket": "7.6.17",
    "@storybook/client-api": "7.6.17",
    "@storybook/preview-web": "7.6.17",
    "@storybook/react": "8.5.2",
    "@storybook/react-vite": "8.5.2",
    "@storybook/testing-library": "0.2.2",
    "@testing-library/react": "16.2.0",
    "@types/lodash": "4.17.14",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/ui": "2.1.8",
    "babel-loader": "9.2.1",
    "happy-dom": "15.11.7",
    "imagetools-core": "7.0.2",
    "lodash": "4.17.21",
    "netlify-cli": "17.38.1",
    "postcss": "8.5.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "8.5.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vite": "6.0.11",
    "vite-imagetools": "7.0.5",
    "vite-plugin-dts": "4.5.0",
    "vitest": "2.1.8",
    "zustand": "5.0.3"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "clsx": "^2.1.1",
    "gsap": "^3.12.7"
  }
}
