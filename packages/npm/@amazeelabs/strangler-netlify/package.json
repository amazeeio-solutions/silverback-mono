{
  "name": "@amazeelabs/strangler-netlify",
  "version": "1.2.5",
  "description": "Netlify function for facading legacy systems.",
  "type": "module",
  "main": "./build/src/index.js",
  "types": "./build/index.d.ts",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf build && swc ./src -d ./build && tsc --emitDeclarationOnly",
    "test:static": "tsc --noEmit && eslint . --quiet"
  },
  "dependencies": {
    "@netlify/functions": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.11",
    "@types/node": "18.19.74",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "keywords": [],
  "author": "AmazeeLabs <development@amazeelabs.com>"
}
