{
  "name": "verdaccio-git",
  "version": "0.1.102",
  "description": "Publish packages to git repositories.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/"
  ],
  "engines": {
    "node": ">=10"
  },
  "dependencies": {
    "@verdaccio/commons-api": "^10.2.0",
    "@verdaccio/local-storage": "10.3.4",
    "@verdaccio/streams": "^10.2.1",
    "file-system": "^2.2.2",
    "fs-extra": "^11.3.0",
    "simple-git": "^3.27.0",
    "sync-directory": "^6.0.5",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@babel/preset-env": "7.26.7",
    "@babel/preset-typescript": "7.26.0",
    "@internal/eslint-config": "workspace:*",
    "@tsconfig/recommended": "1.0.8",
    "@types/express": "5.0.0",
    "@types/fs-extra": "11.0.4",
    "@types/jest": "29.5.14",
    "@types/mock-fs": "4.13.4",
    "@types/node": "16.18.125",
    "@types/tar": "6.1.13",
    "@verdaccio/types": "10.8.0",
    "jest": "29.7.0",
    "mock-fs": "5.4.1",
    "standard-version": "9.5.0",
    "typescript": "5.7.3",
    "verdaccio": "6.0.5"
  },
  "keywords": [
    "verdaccio,plugin,storage,git,verdaccio-git"
  ],
  "license": "MIT",
  "repository": "AmazeeLabs/storage-git",
  "author": "Philipp Melab <philipp.melab@amazee.com>",
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/index.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "pretest": "tsc && pnpm lint && pnpm formatting",
    "test:unit": "jest --coverage",
    "test:integration": "./test",
    "test:staic": "tsc --noEmit && eslint . --quiet"
  }
}
